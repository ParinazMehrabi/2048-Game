<AnchorPane fx:id="anc" prefHeight="606.0" prefWidth="468.0" style="-fx-background-color: #FAF8EF;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.game.view.BoardController">
